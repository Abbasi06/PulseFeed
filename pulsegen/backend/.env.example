# PulseGen Microservice Configuration

# Database: PostgreSQL (shared with pulsefeed)
STORAGE_DATABASE_URL=postgresql://pulseboard:password@localhost:5432/pulseboard

# Message Broker: Redis (shared with pulsefeed)
REDIS_URL=redis://localhost:6379/0

# AI Model: Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Admin API Configuration
ADMIN_API_PORT=8001

# Generator Database: SQLite (local state tracking)
GENERATOR_DB_PATH=./generator.db

# Logging
LOG_LEVEL=INFO
