# Root .env for docker-compose
# Copy to .env and fill in values

# PostgreSQL password (shared across all services)
POSTGRES_PASSWORD=changeme

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Secret (must be a long random string in production)
SECRET_KEY=dev-secret-change-before-production

# CORS allowed origins for pulsefeed_backend (comma-separated)
# ALLOWED_ORIGIN=https://your-domain.com
