# ── Required ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Redis (Celery broker + result backend) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MCP server launch commands ────────────────────────────────────────────────
# These are shell commands used to spawn MCP subprocesses.
MCP_SQL_COMMAND=uv run mcp-sql-server --pg-url postgresql://user:pass@localhost:5432/pulsegen
MCP_STORAGE_COMMAND=uv run mcp-storage-server --pg-url postgresql://user:pass@localhost:5432/pulsegen

# ── GitHub (optional — connector degrades gracefully without it) ──────────────
# Without a token: 60 req/hr. With: 5000 req/hr.
GITHUB_TOKEN=

# ── Gemini model overrides (free-tier defaults) ───────────────────────────────
GATEKEEPER_MODEL=gemini-2.0-flash
EXTRACTOR_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Generator SQLite (local state cache for momentum tracking) ────────────────
GENERATOR_DB_PATH=generator.db

# ── Harvest tuning ────────────────────────────────────────────────────────────
# Target documents to fetch per source per cycle
HARVEST_TARGET_PER_SOURCE=30
# Minimum gatekeeper confidence to proceed to extraction
GATEKEEPER_MIN_CONFIDENCE=0.6
