# PulseFeed Microservice Configuration

# Database: PostgreSQL (shared with pulsegen)
DATABASE_URL=postgresql://pulseboard:password@localhost:5432/pulseboard

# Generator documents database (read-only access to pulsegen's ingested content)
STORAGE_DATABASE_URL=postgresql://pulseboard:password@localhost:5432/pulseboard

# Message Broker: Redis (shared with pulsegen, for rate limiting)
REDIS_URL=redis://localhost:6379/0

# AI Model: Google Gemini (for v2 feed generation via RetrieverAgent)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Secret Key (MUST be changed before production)
SECRET_KEY=dev-secret-change-before-production

# CORS (comma-separated origins for production)
# ALLOWED_ORIGIN=https://your-domain.com

# Cookie security (set true in production with HTTPS)
COOKIE_SECURE=false
